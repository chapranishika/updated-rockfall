# Rockfall-AI — Environment Variables
# First-time setup: cp .env.example .env

# Ports (host machine)
BACKEND_PORT=8000
UI_PORT=3000

# IMPORTANT: Use http://backend:8000 when running with Docker Compose
# Use http://localhost:8000 only for local dev (npm run dev without Docker)
NEXT_PUBLIC_API_URL=http://backend:8000

# Optional MongoDB
MONGO_USER=rockfall
MONGO_PASSWORD=changeme
MONGO_PORT=27017

# Optional alerts
SENDGRID_API_KEY=
ALERT_EMAIL_TO=ops@your-domain.com
